<title>Ibuprofen — Pharma Guide</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans+Arabic:wght@300;400;600;700&family=Space+Grotesk:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d1117;
  --surface: #161b22;
  --surface2: #21262d;
  --border: #30363d;
  --elixir: #f78166;
  --syrup: #79c0ff;
  --compare: #56d364;
  --text: #e6edf3;
  --text2: #8b949e;
  --text3: #484f58;
  --font: 'Space Grotesk', 'IBM Plex Sans Arabic', sans-serif;
  --mono: 'IBM Plex Mono', monospace;
  --tab-h: 64px;
  --header-h: 56px;
}

- { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

html, body {
height: 100%;
overflow: hidden;
background: var(–bg);
color: var(–text);
font-family: var(–font);
}

/* ── HEADER ── */
#header {
position: fixed;
top: 0; left: 0; right: 0;
height: var(–header-h);
background: var(–surface);
border-bottom: 1px solid var(–border);
display: flex;
align-items: center;
padding: 0 16px;
gap: 10px;
z-index: 100;
}
#header-icon { font-size: 22px; }
#header-title {
flex: 1;
font-size: 15px;
font-weight: 700;
letter-spacing: -0.01em;
}
#header-sub {
font-size: 10px;
color: var(–text2);
font-family: var(–mono);
}
.lang-pill {
display: flex;
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 20px;
overflow: hidden;
}
.lang-btn {
padding: 4px 12px;
font-size: 11px;
font-weight: 700;
font-family: var(–mono);
border: none;
background: transparent;
color: var(–text2);
cursor: pointer;
transition: all 0.2s;
border-radius: 20px;
}
.lang-btn.active { background: var(–compare); color: #0d1117; }

/* ── SCREENS ── */
#screens {
position: fixed;
top: var(–header-h);
left: 0; right: 0;
bottom: var(–tab-h);
overflow: hidden;
}

.screen {
position: absolute;
inset: 0;
overflow-y: auto;
padding: 16px 16px 24px;
opacity: 0;
pointer-events: none;
transform: translateY(12px);
transition: opacity 0.25s ease, transform 0.25s ease;
-webkit-overflow-scrolling: touch;
}
.screen.active {
opacity: 1;
pointer-events: all;
transform: translateY(0);
}
.screen::-webkit-scrollbar { display: none; }

/* ── BOTTOM TABS ── */
#tabs {
position: fixed;
bottom: 0; left: 0; right: 0;
height: var(–tab-h);
background: var(–surface);
border-top: 1px solid var(–border);
display: flex;
z-index: 100;
}
.tab {
flex: 1;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
gap: 4px;
cursor: pointer;
transition: background 0.15s;
border: none;
background: transparent;
color: var(–text3);
padding: 8px 0;
}
.tab.active { color: var(–text); }
.tab-icon { font-size: 22px; line-height: 1; }
.tab-label { font-size: 10px; font-weight: 600; font-family: var(–mono); }
.tab-elixir.active  { color: var(–elixir); }
.tab-syrup.active   { color: var(–syrup); }
.tab-compare.active { color: var(–compare); }
.tab-indicator {
position: absolute;
top: -2px;
height: 2px;
width: 33.33%;
border-radius: 2px;
transition: left 0.25s cubic-bezier(0.34,1.2,0.64,1);
}

/* ── HERO CARD ── */
.hero-card {
border-radius: 16px;
padding: 20px;
margin-bottom: 16px;
position: relative;
overflow: hidden;
}
.hero-card::before {
content: attr(data-formula);
position: absolute;
right: -10px; bottom: -10px;
font-family: var(–mono);
font-size: 52px;
opacity: 0.07;
color: #fff;
pointer-events: none;
line-height: 1;
}
.hero-emoji { font-size: 40px; margin-bottom: 10px; display: block; }
.hero-name { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
.hero-sub { font-size: 11px; font-family: var(–mono); opacity: 0.7; }
.hero-elixir  { background: linear-gradient(135deg, #2d1a16, #4a2218); border: 1px solid rgba(247,129,102,0.25); }
.hero-syrup   { background: linear-gradient(135deg, #141e2d, #1a3050); border: 1px solid rgba(121,192,255,0.25); }
.hero-compare { background: linear-gradient(135deg, #131d15, #1a3020); border: 1px solid rgba(86,211,100,0.25); }

/* ── ACCORDION ── */
.accordion { margin-bottom: 10px; border-radius: 12px; overflow: hidden; border: 1px solid var(–border); }
.acc-header {
display: flex;
align-items: center;
padding: 14px 16px;
gap: 10px;
cursor: pointer;
background: var(–surface);
user-select: none;
transition: background 0.15s;
}
.acc-header:active { background: var(–surface2); }
.acc-icon { font-size: 18px; flex-shrink: 0; }
.acc-title { font-size: 13px; font-weight: 600; flex: 1; }
.acc-arrow {
font-size: 12px;
color: var(–text2);
transition: transform 0.25s ease;
flex-shrink: 0;
}
.accordion.open .acc-arrow { transform: rotate(180deg); }

.acc-body {
max-height: 0;
overflow: hidden;
transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1);
background: var(–surface2);
}
.accordion.open .acc-body { max-height: 1200px; }
.acc-content { padding: 14px 16px; }

/* ── INFO ROWS ── */
.info-row {
display: flex;
flex-direction: column;
gap: 3px;
padding: 10px 0;
border-bottom: 1px solid rgba(48,54,61,0.6);
}
.info-row:last-child { border-bottom: none; padding-bottom: 0; }
.info-lbl {
font-size: 10px;
font-weight: 700;
letter-spacing: 0.06em;
text-transform: uppercase;
font-family: var(–mono);
color: var(–text2);
}
.info-val { font-size: 13px; line-height: 1.55; color: var(–text); }

/* Badges */
.badges { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
.badge {
padding: 3px 9px;
border-radius: 5px;
font-size: 11px;
font-weight: 600;
font-family: var(–mono);
}
.badge-e { background: rgba(247,129,102,0.12); color: var(–elixir); border: 1px solid rgba(247,129,102,0.25); }
.badge-s { background: rgba(121,192,255,0.12); color: var(–syrup);  border: 1px solid rgba(121,192,255,0.25); }
.badge-pom { background: rgba(255,188,46,0.12); color: #febc2e; border: 1px solid rgba(255,188,46,0.25); }
.badge-otc { background: rgba(86,211,100,0.12); color: var(–compare); border: 1px solid rgba(86,211,100,0.25); }

.warning {
display: flex;
align-items: flex-start;
gap: 8px;
padding: 10px 12px;
border-radius: 8px;
background: rgba(255,188,46,0.08);
border: 1px solid rgba(255,188,46,0.2);
margin-top: 8px;
font-size: 12px;
line-height: 1.5;
color: #febc2e;
}

/* ── PK CHART ── */
.pk-wrap {
background: var(–surface);
border-radius: 10px;
padding: 12px;
margin-bottom: 10px;
border: 1px solid var(–border);
}
.pk-title {
font-size: 11px;
font-weight: 700;
font-family: var(–mono);
color: var(–compare);
letter-spacing: 0.06em;
text-transform: uppercase;
margin-bottom: 10px;
}
.pk-chart { width: 100%; height: 110px; }
.pk-legend {
display: flex;
gap: 16px;
margin-top: 8px;
justify-content: center;
}
.pk-leg-item { display: flex; align-items: center; gap: 6px; font-size: 11px; font-family: var(–mono); }
.pk-leg-dot { width: 20px; height: 3px; border-radius: 2px; }

/* ── COMPARE TABLE MOBILE ── */
.cmp-row {
border-radius: 10px;
overflow: hidden;
margin-bottom: 10px;
border: 1px solid var(–border);
}
.cmp-param {
background: var(–surface2);
padding: 8px 14px;
font-size: 10px;
font-weight: 700;
font-family: var(–mono);
color: var(–text2);
text-transform: uppercase;
letter-spacing: 0.06em;
}
.cmp-cells {
display: grid;
grid-template-columns: 1fr 1fr;
}
.cmp-cell {
padding: 10px 12px;
font-size: 12px;
line-height: 1.45;
border-top: 1px solid var(–border);
}
.cmp-cell:first-child { border-right: 1px solid var(–border); }
.cmp-cell-hdr {
font-size: 10px;
font-weight: 700;
font-family: var(–mono);
margin-bottom: 4px;
letter-spacing: 0.04em;
}
.cell-e .cmp-cell-hdr { color: var(–elixir); }
.cell-s .cmp-cell-hdr { color: var(–syrup); }
.cell-e { color: rgba(247,129,102,0.9); }
.cell-s { color: rgba(121,192,255,0.9); }

/* ── RTL ── */
body.rtl { direction: rtl; }
body.rtl .acc-arrow { transform: rotate(0deg); }
body.rtl .accordion.open .acc-arrow { transform: rotate(-180deg); }

/* scroll reveal */
@keyframes fadeUp {
from { opacity:0; transform:translateY(16px); }
to   { opacity:1; transform:translateY(0); }
}
.accordion { animation: fadeUp 0.3s ease both; }
.accordion:nth-child(2) { animation-delay: 0.04s; }
.accordion:nth-child(3) { animation-delay: 0.08s; }
.accordion:nth-child(4) { animation-delay: 0.12s; }
.accordion:nth-child(5) { animation-delay: 0.16s; }
</style>

</head>
